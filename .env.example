# API base used by axios in renderer.
# Leave empty to use relative '/' and call '/api/...'.
# Google OAuth in desktop requires this (or VITE_API_PROXY_TARGET) to be absolute http(s) URL.
VITE_API_BASE_URL=

# Dev-only proxy target for Vite server (/api -> target).
# Example: https://v-xs.com
VITE_API_PROXY_TARGET=

# Compatible with frontend env naming.
# You can copy NEXT_PUBLIC_BASE_URL from D:\vxspace\frontend\.env
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_DOMAIN_AUTH=
NEXT_PUBLIC_DOMAIN=

# LiveKit media server URL for video conference (required for real video).
# Example local: ws://127.0.0.1:7880
# Example production: wss://talkspace.v-xs.com
VITE_LIVEKIT_URL=
NEXT_PUBLIC_LIVEKIT_URL=

# Dev troubleshooting only:
# set 1 to allow insecure HTTPS certs in Electron OAuth popup.
ELECTRON_ALLOW_INSECURE_CERT=0
