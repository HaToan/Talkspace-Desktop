{
  "name": "talkspace-desktop",
  "version": "0.1.4",
  "private": true,
  "description": "Electron desktop app for TalkSpace features",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "typecheck": "tsc --noEmit",
    "pack:win": "npm run build && electron-builder --win",
    "pack:win:x64": "npm run build && electron-builder --win --x64",
    "pack:win:x32": "npm run build && electron-builder --win --ia32",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:linux": "npm run build && electron-builder --linux",
    "pack:linux:deploy": "npm run pack:linux && npm run deploy:softwarex",
    "pack": "npm run build && electron-builder",
    "serve:updates:local": "npx http-server release -p 5500 -c-1",
    "deploy:softwarex": "powershell -ExecutionPolicy Bypass -File scripts/deploy-softwarex.ps1"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@livekit/track-processors": "^0.7.2",
    "axios": "^1.9.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "livekit-client": "^2.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  }
}
